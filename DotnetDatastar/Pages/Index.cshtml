@page
@model IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Todo List</title>
    <style>
        :root {
            color-scheme: light dark;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body {
            max-width: 42rem;
            margin: 2rem auto;
            padding: 0 1rem;
            line-height: 1.5;
        }

        form.add-form {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        input[type="text"] {
            flex: 1;
            padding: 0.75rem;
        }

        button {
            padding: 0.75rem 1rem;
            cursor: pointer;
        }

        ul {
            list-style: none;
            padding: 0;
            margin: 1rem 0 0;
        }

        li {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.75rem 1rem;
            border: 1px solid rgba(127, 127, 127, 0.35);
            border-radius: 0.5rem;
            margin-bottom: 0.75rem;
        }

        .todo-title.done {
            text-decoration: line-through;
            opacity: 0.7;
        }

        .meta {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        .status {
            font-size: 0.875rem;
            opacity: 0.8;
        }

        .empty {
            opacity: 0.75;
            font-style: italic;
        }

        .validation {
            color: #c62828;
            margin-top: 0.75rem;
            min-height: 1.25rem;
        }

        .delete-form {
            margin: 0;
        }

        .field-validation-error {
            color: #c62828;
            display: block;
            margin-top: 0.35rem;
        }
    </style>
</head>
<body>
    <h1>Todo List</h1>

    <form method="post" asp-page-handler="Add" class="add-form">
        <div style="flex: 1;">
            <input asp-for="Title" type="text" maxlength="280" placeholder="Add a new todo" autocomplete="off" />
            <span asp-validation-for="Title"></span>
        </div>
        <button type="submit">Add Todo</button>
    </form>

    <div class="validation" asp-validation-summary="ModelOnly"></div>

    @if (Model.Todos.Count == 0)
    {
        <div class="empty">No todos yet.</div>
    }
    else
    {
        <ul>
            @foreach (var todo in Model.Todos)
            {
                <li>
                    <div class="meta">
                        <span class="todo-title @(todo.IsDone ? "done" : string.Empty)">@todo.Title</span>
                        <span class="status">@(todo.IsDone ? "Done" : "Open")</span>
                    </div>

                    <form method="post" asp-page-handler="Delete" class="delete-form">
                        <input type="hidden" name="id" value="@todo.Id" />
                        <button type="submit">Delete</button>
                    </form>
                </li>
            }
        </ul>
    }
</body>
</html>

