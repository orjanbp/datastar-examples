@page "/"
@model HomeModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Express Datastar</title>
    <style>
        :root {
            color-scheme: light dark;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body {
            max-width: 42rem;
            margin: 2rem auto;
            padding: 0 1rem;
            line-height: 1.5;
        }

        main {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        h1 {
            font-size: 2rem;
            margin: 0;
        }

        .intro {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .intro p {
            margin: 0;
        }

        code {
            background: rgba(127, 127, 127, 0.1);
            padding: 0.25rem 0.5rem;
            border-radius: 0.25rem;
            font-family: monospace;
        }

        .links {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .button {
            display: inline-block;
            padding: 0.75rem 1rem;
            background-color: #007acc;
            color: white;
            text-decoration: none;
            border-radius: 0.5rem;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            transition: background-color 0.2s;
        }

        .button:hover {
            background-color: #005a9e;
        }

        .button--ghost {
            background-color: transparent;
            color: #007acc;
            border: 1px solid #007acc;
        }

        .button--ghost:hover {
            background-color: rgba(0, 122, 204, 0.1);
        }

        ul {
            margin: 0;
            padding-left: 1.5rem;
        }

        li {
            margin: 0.5rem 0;
        }

        a {
            color: #007acc;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <main>
        <div class="intro">
            <h1>Hello World</h1>
            <p>This application now separates browser-facing pages from JSON API endpoints.</p>
            <p>The landing page is served from <code>/</code>, while resource endpoints live under <code>/api</code>.</p>
            <p>
                <a class="button" href="/todo">Go to Todos</a>
            </p>
        </div>

        <div class="links">
            <h2>API Documentation</h2>
            <ul>
                <li>Browse this page at <a href="/">home</a></li>
                <li>Fetch all items at <a href="/api/todo">/api/todo</a></li>
                <li>Organize future HTML routes under <code>Pages/</code> and API routes in the Minimal API</li>
            </ul>
        </div>
    </main>
</body>
</html>
