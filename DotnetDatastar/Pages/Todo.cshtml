@page "/todo"
@model TodoModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Todo</title>
    <style>
        :root {
            color-scheme: light dark;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body {
            max-width: 42rem;
            margin: 2rem auto;
            padding: 0 1rem;
            line-height: 1.5;
        }

        main {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .todo-page {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .todo-page__header {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .todo-page__heading {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            margin: 0;
        }

        .todo-page__eyebrow {
            color: #666;
            font-size: 0.875rem;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .todo-page__heading h1 {
            margin: 0;
            font-size: 2rem;
        }

        .todo-page__description {
            color: #666;
            margin: 0;
            font-size: 0.95rem;
        }

        .button {
            display: inline-block;
            padding: 0.75rem 1rem;
            background-color: #007acc;
            color: white;
            text-decoration: none;
            border-radius: 0.5rem;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            transition: background-color 0.2s;
        }

        .button:hover {
            background-color: #005a9e;
        }

        .button--ghost {
            background-color: transparent;
            color: #007acc;
            border: 1px solid #007acc;
        }

        .button--ghost:hover {
            background-color: rgba(0, 122, 204, 0.1);
        }

        .todo-panel {
            border: 1px solid rgba(127, 127, 127, 0.2);
            border-radius: 0.5rem;
            padding: 1rem;
        }

        .todo-panel--stacked {
            display: flex;
            flex-direction: column;
        }

        .todo-toolbar {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1rem;
        }

        .todo-toolbar__label {
            display: none;
        }

        .todo-toolbar__controls {
            display: flex;
            gap: 0.5rem;
            flex: 1;
        }

        .todo-toolbar__input {
            flex: 1;
            padding: 0.75rem;
            border: 1px solid rgba(127, 127, 127, 0.35);
            border-radius: 0.25rem;
            font-size: 1rem;
        }

        .todo-toolbar__input:focus {
            outline: none;
            border-color: #007acc;
        }

        .todo-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .todo-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            padding: 0.75rem;
            border: 1px solid rgba(127, 127, 127, 0.35);
            border-radius: 0.5rem;
            margin-bottom: 0.75rem;
        }

        .todo-item__body {
            flex: 1;
        }

        .todo-item__label {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            margin: 0;
        }

        .todo-item__label-text {
            margin: 0;
        }

        .todo-item__actions {
            display: flex;
            gap: 0.5rem;
        }

        .todo-form {
            margin: 0;
        }

        .empty {
            opacity: 0.75;
            font-style: italic;
            padding: 1rem;
        }
    </style>
</head>
<body>
    <main>
        <div class="todo-page">
            <div class="todo-page__header">
                <div class="todo-page__heading">
                    <p class="todo-page__eyebrow">Work queue</p>
                    <h1>Todo</h1>
                    <p class="todo-page__description">Add and delete todos using regular form posts.</p>
                </div>
                <a class="button button--ghost" href="/">Back home</a>
            </div>

            <section class="todo-panel" aria-label="Todo controls">
                <form class="todo-toolbar" method="post" action="/todo/create">
                    <label class="todo-toolbar__label" for="todo-name">Add a todo item</label>
                    <div class="todo-toolbar__controls">
                        <input id="todo-name" class="todo-toolbar__input" type="text" name="name" placeholder="Plan the next task" autocomplete="off" required />
                        <button class="button" type="submit">Add todo</button>
                    </div>
                </form>
            </section>

            <section class="todo-panel todo-panel--stacked" aria-label="Todo items">
                <ul class="todo-list">
                    @if (Model.Todos.Count == 0)
                    {
                        <li class="todo-item">
                            <div class="todo-item__body">
                                <span class="todo-item__label-text empty">No todo items yet.</span>
                            </div>
                        </li>
                    }
                    else
                    {
                        @foreach (var todo in Model.Todos)
                        {
                            <li class="todo-item">
                                <div class="todo-item__body">
                                    <label class="todo-item__label">
                                        <span class="todo-item__label-text">@todo.Name</span>
                                    </label>
                                </div>
                                <div class="todo-item__actions">
                                    <form method="post" action="/todo/delete/@todo.Id" class="todo-form">
                                        <button class="button button--ghost" type="submit">Delete</button>
                                    </form>
                                </div>
                            </li>
                        }
                    }
                </ul>
            </section>
        </div>
    </main>
</body>
</html>
